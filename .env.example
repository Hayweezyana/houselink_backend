# ─── Database (Neon / any Postgres) ─────────────────────────────────────────
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=
# PGSSLMODE=require   # uncomment for Neon

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (Gmail App Password) ──────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── Paystack ────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-frontend.up.railway.app

# ─── Optional ────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
