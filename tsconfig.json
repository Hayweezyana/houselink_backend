{
  "compilerOptions": {

    "typeRoots": ["./types", "./node_modules/@types"],
    
    /* Language and Environment */
    "target": "es2016",                                  
    
    /* Modules */
    "module": "commonjs",
    
    "outDir": "./dist",
    "rootDir": "./",
    
    "esModuleInterop": true,                                                      
    "forceConsistentCasingInFileNames": true,            

    "strict": true,                                      
    
    "skipLibCheck": true                                 
  },
  "include": ["src/**/*", "src/types/**/*.d.ts", "db.ts"],
  "exclude": ["node_modules", "dist"]
}
